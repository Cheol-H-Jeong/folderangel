# --- Local user data: NEVER commit ---
# Per-run logs (the app writes these under ~/.folderangel/logs/, but
# defensively also block any *.log anywhere in the tree in case a user
# copies one in for debugging).
*.log
logs/
.folderangel/
folderangel_logs/

